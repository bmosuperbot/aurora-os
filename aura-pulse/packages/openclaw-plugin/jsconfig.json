{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "checkJs": true,
        "strict": true,
        "exactOptionalPropertyTypes": true,
        "noUncheckedIndexedAccess": true,
        "allowJs": true,
        "maxNodeModuleJsDepth": 1,
        "paths": {
            "@aura/contract-runtime": ["../contract-runtime/src/index.d.ts"],
            "@aura/contract-runtime/*": ["../contract-runtime/src/*"]
        }
    },
    "include": ["src/**/*", "*.js"],
    "exclude": ["node_modules", "dist", "tests", "src/test-support"]
}
