{
    "name": "@aura/aura-pulse",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "index.js",
    "openclaw": {
        "extensions": ["./index.js"]
    },
    "engines": { "node": ">=24.0.0" },
    "scripts": {
        "build:standalone": "node ../../scripts/build-openclaw-standalone.mjs",
        "test":          "vitest run",
        "test:watch":    "vitest",
        "test:coverage": "vitest run --coverage",
        "demo:artist":   "node tests/manual/artist-reseller-demo.mjs",
        "typecheck":     "tsc -p jsconfig.json --noEmit",
        "lint":          "eslint src tests index.js setup-entry.js api.js runtime-api.js",
        "lint:fix":      "eslint src tests index.js setup-entry.js api.js runtime-api.js --fix"
    },
    "dependencies": {
        "@aura/contract-runtime": "workspace:*",
        "@sinclair/typebox": "^0.34.0",
        "chokidar": "^4.0.0",
        "diff-match-patch": "^1.0.5",
        "ws": "^8.18.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@types/diff-match-patch": "^1.0.36",
        "@types/node": "^24.0.0",
        "@types/ws": "^8.5.10",
        "@vitest/coverage-v8": "^4.1.2",
        "eslint": "^9.0.0",
        "globals": "^15.0.0",
        "typescript": "^5.5.0",
        "vitest": "^4.1.2"
    },
    "peerDependencies": {
        "openclaw": ">=2026.3.22"
    },
    "peerDependenciesMeta": {
        "openclaw": { "optional": true }
    }
}
