{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "checkJs": true,
        "strict": true,
        "exactOptionalPropertyTypes": true,
        "noUncheckedIndexedAccess": true,
        "allowJs": true,
        "maxNodeModuleJsDepth": 1
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist", "tests"]
}
